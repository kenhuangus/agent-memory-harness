{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m cookbook_memory.adapters.claude_code.hooks_handler SessionStart",
            "env": { "MEMORY_STORE": "${CLAUDE_PROJECT_DIR}/.cookbook-memory" }
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m cookbook_memory.adapters.claude_code.hooks_handler UserPromptSubmit",
            "env": { "MEMORY_STORE": "${CLAUDE_PROJECT_DIR}/.cookbook-memory" }
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m cookbook_memory.adapters.claude_code.hooks_handler Stop",
            "async": true,
            "env": { "MEMORY_STORE": "${CLAUDE_PROJECT_DIR}/.cookbook-memory" }
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m cookbook_memory.adapters.claude_code.hooks_handler PreCompact",
            "env": { "MEMORY_STORE": "${CLAUDE_PROJECT_DIR}/.cookbook-memory" }
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m cookbook_memory.adapters.claude_code.hooks_handler PostCompact",
            "env": { "MEMORY_STORE": "${CLAUDE_PROJECT_DIR}/.cookbook-memory" }
          }
        ]
      }
    ]
  }
}
