{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cookbook-memory\" hook SessionStart",
            "env": { "MEMORY_STORE": "${CLAUDE_PROJECT_DIR}/.cookbook-memory" }
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cookbook-memory\" hook UserPromptSubmit",
            "env": { "MEMORY_STORE": "${CLAUDE_PROJECT_DIR}/.cookbook-memory" }
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cookbook-memory\" hook Stop",
            "async": true,
            "env": { "MEMORY_STORE": "${CLAUDE_PROJECT_DIR}/.cookbook-memory" }
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cookbook-memory\" hook PreCompact",
            "env": { "MEMORY_STORE": "${CLAUDE_PROJECT_DIR}/.cookbook-memory" }
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cookbook-memory\" hook PostCompact",
            "env": { "MEMORY_STORE": "${CLAUDE_PROJECT_DIR}/.cookbook-memory" }
          }
        ]
      }
    ]
  }
}
