# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/
env/
# uv lockfiles (these are libraries, not apps — installs are resolved fresh)
uv.lock
**/uv.lock

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Secrets / local environment
.env
.env.*
!.env.example

# Agent run scratch (agent-roster / local tooling output)
work/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Daydream local state (per ADR-dreaming-009)
*.daydream-events.jsonl

# Daydream FP/FN audit (per ADR-dreaming-011 — contains pre-redaction text;
# MUST never be committed)
*.redact-audit.jsonl

# Daydream sidecar state (per ADR-harness-004)
*.daydream-state.json

# SQLite runtime temp files. WAL (write-ahead log) + SHM (shared memory) are
# transient artifacts SQLite creates beside any *.db opened in WAL mode — they
# get created/recreated every time `make ui` or a benchmark reader touches a
# committed store, then dirty `git status` after the connection closes. The
# .db itself is the real data; these companions are not.
*.db-wal
*.db-shm

# VISTA seed live-run sandbox + scratch (not source)
eval/.claude-sandbox-vcs/
eval/projects/
eval/_*.sh
eval/_*.py
