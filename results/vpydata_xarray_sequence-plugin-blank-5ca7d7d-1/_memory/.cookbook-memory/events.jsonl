{"ts": 0.0, "op": "recall", "ids": ["mem_0fdf325f", "mem_680768da", "mem_ad9a2162", "mem_1d16c4c3", "mem_d7b3ce68"], "query": "swap_dims issue modifying original object xarray", "meta": {"k": 5, "n": 5, "hits": [{"id": "mem_0fdf325f", "content": "xarray dimension 'method' conflicts with sel() method parameter - fixed by using sel(indexers=key) instead of sel(**key) in _LocIndexer.__getitem__ for both DataArray and Dataset", "score": 0.583684, "tokens": 44, "rank": 0, "timestamp": 1782499146.9609997}, {"id": "mem_680768da", "content": "Fixed to_unstacked_dataset for single-dimension variables by dropping MultiIndex coordinates that are not actual dimensions of resulting arrays.", "score": 0.571694, "tokens": 36, "rank": 1, "timestamp": 1782496114.9964638}, {"id": "mem_ad9a2162", "content": "Fixed in xarray/core/computation.py: Changed lambda access of attrs[1] to hasattr(x, 'attrs') check - returns dict(x.attrs) if x has attrs, otherwise {}", "score": 0.56784, "tokens": 38, "rank": 2, "timestamp": 1782496941.4718962}, {"id": "mem_1d16c4c3", "content": "Added test case test_where_attrs_with_scalar in xarray/tests/test_computation.py to verify fix for scalar x argument with keep_attrs=True", "score": 0.533012, "tokens": 34, "rank": 3, "timestamp": 1782496941.4718962}, {"id": "mem_d7b3ce68", "content": "The base commit is 7c4e2ac83f7b4306296ff9b7b51aaf016e5ad614 in the pydata/xarray repository.", "score": 0.518656, "tokens": 23, "rank": 4, "timestamp": 1782497197.632577}]}}
